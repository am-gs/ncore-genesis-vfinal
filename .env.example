# ════════════════════════════════════════════════════════════════════
# NCore Genesis vFinal — Environment Variables
# Copy to ~/.ncore/.env and fill in real values
# ════════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
VAST_API_KEY=

# ── Free Model Tiers (v7.6 — April 7 2026) ──────────────────────────────────
FAST_MODEL=openai/gpt-oss-20b:free
FREE_CODER_MODEL=qwen/qwen3-coder-480b-a35b-instruct:free
FREE_REASONING=deepseek/deepseek-r1:free
FALLBACK_FREE=google/gemini-2.0-flash-lite-001
WORKER_MODEL=deepseek/deepseek-chat
OPUS_MODEL=anthropic/claude-opus-4.6

# ── LiteLLM Fallback Chain ────────────────────────────────────────────────
# If primary model fails, falls back through this chain automatically
LITELLM_FALLBACK_MODELS=openai/gpt-oss-20b:free,deepseek/deepseek-chat,google/gemini-2.0-flash-lite-001
UNCENSORED_LOCAL=huihui_ai/qwen3.5-abliterated:35b-a3b
AGENT_ZERO_URL=http://localhost:8090
LOCAL_MODEL=ncore-critic
LOCAL_REASONING=ncore-reasoning

# ── OSINT + Fraud APIs ────────────────────────────────────────────────────────
HIBP_API_KEY=
SHODAN_API_KEY=
ABUSEIPDB_KEY=
EMAILREP_KEY=
ETHERSCAN_KEY=
INTELX_API_KEY=
NUMVERIFY_KEY=
LEAKCHECK_KEY=
DEHASHED_KEY=
FULLCONTACT_KEY=
HUNTERIO_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── OPTIONAL: Vast.ai serverless endpoints ────────────────────────────
# Set these to the URL of your always-warm Vast serverless workers
# Format: https://<instance-ip>:<port>/v1
VAST_CODER_URL=
VAST_UNCENSORED_URL=

# ── OPTIONAL: pre-warmed pod IDs (zero cold-start) ───────────────────
# Run: vastai create instance <offer_id> --image vastai/comfyui-wan22:latest ...
# Then set the returned instance ID here to avoid 120s startup on every video
VAST_RESERVE_VIDEO_ID=
VAST_RESERVE_IMAGE_ID=

# ── OPTIONAL: cost tracking via Supabase ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...

# ── OPTIONAL: Telegram C2 bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AUTO-CONFIGURED by deploy script ─────────────────────────────────
NCORE_REDIS_UDS=/var/run/redis/redis-server.sock
NCORE_QUANTIZED_DIR=/tmp/ncore_quantized

# ── SYSTEM ────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
OPENROUTER_DAILY_BUDGET_USD=25.0
DAILY_SPEND_ALERT_USD=15.0
