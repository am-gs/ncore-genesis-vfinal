# ════════════════════════════════════════════════════════════════════
# NCore Genesis vFinal — Environment Variables
# Copy to ~/.ncore/.env and fill in real values
# ════════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
VAST_API_KEY=...

# ── OPTIONAL: Vast.ai serverless endpoints ────────────────────────────
# Set these to the URL of your always-warm Vast serverless workers
# Format: https://<instance-ip>:<port>/v1
VAST_CODER_URL=
VAST_UNCENSORED_URL=

# ── OPTIONAL: pre-warmed pod IDs (zero cold-start) ───────────────────
# Run: vastai create instance <offer_id> --image vastai/comfyui-wan22:latest ...
# Then set the returned instance ID here to avoid 120s startup on every video
VAST_RESERVE_VIDEO_ID=
VAST_RESERVE_IMAGE_ID=

# ── OPTIONAL: cost tracking via Supabase ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...

# ── OPTIONAL: Telegram C2 bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AUTO-CONFIGURED by deploy script ─────────────────────────────────
NCORE_REDIS_UDS=/var/run/redis/redis-server.sock
NCORE_QUANTIZED_DIR=/tmp/ncore_quantized

# ── SYSTEM ────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
OPENROUTER_DAILY_BUDGET_USD=25.0
DAILY_SPEND_ALERT_USD=15.0
