# ═══════════════════════════════════════════════════════════════════
#  NLLM.ING — Environment Configuration
#  Copy this file to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════════

# ── External GPU Inference Providers (at least one required) ─────────
# All providers route through Bifrost v2 (no local Ollama required)
CEREBRAS_API_KEY=
GROQ_API_KEY=
SAMBANOVA_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
DEEPINFRA_API_KEY=
HYPERBOLIC_API_KEY=
NEBIUS_API_KEY=
MODAL_API_KEY=

# ── Internal services ──────────────────────────────────────────────
BIFROST_URL=http://127.0.0.1:8000
MISSION_CONTROL_URL=http://127.0.0.1:3004
POSTGRES_PASSWORD=
GRAFANA_PASSWORD=

# ── Optional: Bifrost Gateway ──────────────────────────────────────
# Local sovereign Bifrost proxy (multi-provider router) runs on port 8000
BIFROST_API_KEY=nllm-local
BIFROST_BUDGET_DAILY_USD=2.0

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL (set strong password for production)
POSTGRES_PASSWORD=change-me-to-64-char-random-string

# ── Redis ─────────────────────────────────────────────────────────
# Set only if using external Redis; Docker Compose handles local
# REDIS_URL=redis://localhost:6379

# ── Model Selection (all via OpenRouter) ──────────────────────────
# FAST: GPT-4.1-nano (free, fastest)
FAST_MODEL=openai/gpt-4.1-nano

# CODER: DeepSeek Chat (cheap, uncensored for code)
CODER_MODEL=deepseek/deepseek-chat

# REASONING: DeepSeek R1 (free, strong reasoning)
REASONING_MODEL=deepseek/deepseek-r1

# WORKER: DeepSeek V3 (cheapest paid frontier)
WORKER_MODEL=deepseek/deepseek-chat

# OPUS: Claude 4.6 (budget-gated, complex only)
OPUS_MODEL=anthropic/claude-opus-4.6

# KIMI: Kimi K2.6 (256K context, long-document specialist)
KIMI_MODEL=moonshot/kimi-k2.6

# PLANNER: Task decomposition (cheap + fast)
PLANNER_MODEL=openai/gpt-4.1-nano

# ── Dashboard ─────────────────────────────────────────────────────
# Set for Vercel deployment (used by apps/nllm-dashboard/.env.production)
NEXT_PUBLIC_API_URL=https://api.nllm.ing
NEXT_PUBLIC_WS_URL=wss://api.nllm.ing/ws
NEXT_PUBLIC_BIFROST_URL=https://api.nllm.ing/bifrost

# ── Cloud Deployment ──────────────────────────────────────────────
# Domain for SSL certificate (Let's Encrypt)
NLLM_DOMAIN=api.nllm.ing
NLLM_EMAIL=admin@nllm.ing

# ── Optional: Supabase (legacy cost tracking) ────────────────────
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_KEY=eyJ...

# ── Optional: Vast.ai (GPU media generation) ──────────────────────
# VAST_API_KEY=xxxxxxxx
